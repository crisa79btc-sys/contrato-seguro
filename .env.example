# ============================================
# ContratoSeguro - Variaveis de Ambiente
# ============================================
# Copie este arquivo para .env.local e preencha os valores.
# Nunca commite o .env.local no repositorio.

# --------------------------------------------
# Supabase
# --------------------------------------------
# URL do projeto Supabase (encontrado em Settings > API)
NEXT_PUBLIC_SUPABASE_URL=

# Chave anonima (publica) do Supabase - usada no client-side
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave service_role do Supabase - NUNCA expor no client-side
# Usada apenas no server-side para operacoes administrativas
SUPABASE_SERVICE_ROLE_KEY=

# --------------------------------------------
# Claude API (Anthropic)
# --------------------------------------------
# Chave de API da Anthropic para acesso ao Claude
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --------------------------------------------
# Mercado Pago (desativado na beta)
# --------------------------------------------
# Access token para API do Mercado Pago (server-side)
MERCADO_PAGO_ACCESS_TOKEN=

# Chave publica do Mercado Pago (client-side)
MERCADO_PAGO_PUBLIC_KEY=

# Secret para validar webhooks do Mercado Pago
MERCADO_PAGO_WEBHOOK_SECRET=

# --------------------------------------------
# Inngest (Background Jobs)
# --------------------------------------------
# Chave para envio de eventos ao Inngest
INNGEST_EVENT_KEY=

# Chave para validar requisicoes do Inngest
INNGEST_SIGNING_KEY=

# --------------------------------------------
# Configuracao do App
# --------------------------------------------
# URL publica da aplicacao (sem barra no final)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature flag: habilita/desabilita cobranca
# Na beta, manter como false (tudo gratuito)
BILLING_ENABLED=false

# Numero de analises gratuitas por usuario
# 0 = ilimitado (consistente com SQL: 0 significa sem limite)
FREE_ANALYSES_LIMIT=0

# Numero de correcoes gratuitas por usuario
# 0 = ilimitado (consistente com SQL: 0 significa sem limite)
FREE_CORRECTIONS_LIMIT=0

# Feature flag: habilita/desabilita templates de contrato
TEMPLATES_ENABLED=false

# Feature flag: permite upload sem autenticacao (modo anonimo)
ANONYMOUS_UPLOAD_ENABLED=true

# Tamanho maximo de upload em MB
MAX_UPLOAD_SIZE_MB=10

# Dias ate expirar/deletar dados do contrato
CONTRACT_EXPIRY_DAYS=7

# --------------------------------------------
# Modelos de IA
# --------------------------------------------
# Modelo usado para analise de contratos
AI_MODEL_ANALYSIS=claude-haiku-4-5-20251001

# Modelo usado para correcao de contratos
AI_MODEL_CORRECTION=claude-haiku-4-5-20251001

# Modelo usado para classificacao de tipo de contrato
AI_MODEL_CLASSIFIER=claude-haiku-4-5-20251001

# Modelo usado para script de negociacao
AI_MODEL_NEGOTIATION=claude-haiku-4-5-20251001

# Max tokens para resposta de analise
AI_MAX_TOKENS_ANALYSIS=4096

# Max tokens para resposta de correcao (maior pois gera texto completo)
AI_MAX_TOKENS_CORRECTION=8192

# --------------------------------------------
# Rate Limiting
# --------------------------------------------
# Maximo de uploads por hora por usuario
RATE_LIMIT_UPLOADS_PER_HOUR=10

# Maximo de analises por mes por usuario
# Na beta, valor alto para simular uso ilimitado
RATE_LIMIT_ANALYSES_PER_MONTH=999

# --------------------------------------------
# Criptografia
# --------------------------------------------
# Chave AES-256 para criptografar contratos em repouso
# Gere com: openssl rand -hex 32
CONTRACTS_ENCRYPTION_KEY=

# --------------------------------------------
# Sentry (opcional - monitoramento de erros)
# --------------------------------------------
# DSN do Sentry para server-side
SENTRY_DSN=

# DSN do Sentry para client-side
NEXT_PUBLIC_SENTRY_DSN=
